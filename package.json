{
  "name": "pokegrade",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n engine,web -c blue,green \"npm:dev:engine\" \"npm:dev:web\"",
    "dev:lan": "concurrently -k -n engine,web -c blue,green \"npm:dev:engine\" \"npm:dev:web:lan\"",
    "dev:engine": "uv run --project engine uvicorn pokegrade.app:app --host 127.0.0.1 --port 8000 --reload --reload-dir engine/pokegrade",
    "dev:web": "next dev",
    "dev:web:lan": "next dev -H 0.0.0.0 -p 3000",
    "engine:test": "uv run --project engine pytest -q",
    "build": "next build",
    "start": "next start",
    "lint": "eslint"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "concurrently": "^9.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
