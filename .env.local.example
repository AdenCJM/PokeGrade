# Copy this file to .env.local and fill in your key.
#   cp .env.local.example .env.local
#
# Both the Next web app and the Python engine read this file (the engine loads
# it from the repo root), so the key lives in one place.

# Required: your Anthropic API key (https://console.anthropic.com/settings/keys)
# Used by the engine's soft-pillar adjudicator. Without it, the engine still
# measures centering and returns a verdict, but corners/edges/surface are routed
# to an in-hand check rather than assessed.
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the adjudicator model.
#   claude-opus-4-8     (default) — most accurate visual reasoning, slower (~15-40s)
#   claude-sonnet-4-6   — faster, cheaper, slightly less careful
MODEL=claude-opus-4-8

# Optional: where the Next route reaches the FastAPI engine. Default is fine for
# `npm run dev`, which starts the engine on 127.0.0.1:8000 alongside Next.
# ENGINE_URL=http://127.0.0.1:8000
