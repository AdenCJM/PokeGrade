# Copy this file to .env.local and fill in your key.
#   cp .env.local.example .env.local

# Required: your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the grading model.
#   claude-opus-4-8     (default) — most accurate visual reasoning, slower (~15-40s)
#   claude-sonnet-4-6   — faster, cheaper, slightly less careful
MODEL=claude-opus-4-8
